rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null && request.auth.token.email_verified == true;
    }

    function isOwner(resourceData) {
      return isSignedIn() && resourceData != null && resourceData.userId == request.auth.uid;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource != null ? request.resource.data : null;
    }

    function existing() {
      return resource != null ? resource.data : null;
    }

    // --- Validation Helpers ---
    function isValidTransaction(data) {
      return data.keys().hasAll(['id', 'amount', 'type', 'category', 'paymentMethod', 'date', 'userId'])
        && data.id is string && data.id.size() <= 128
        && data.amount is number
        && data.type in ['income', 'expense', 'refund']
        && data.paymentMethod in ['CASH', 'CARD', 'ZELLE']
        && data.category is string && data.category.size() <= 100
        && (!('items' in data) || (data.items is list && data.items.size() <= 50))
        && data.userId == request.auth.uid;
    }

    function isValidInventory(data) {
      return data.keys().hasAll(['id', 'name', 'category', 'quantity', 'price', 'userId'])
        && data.id is string && data.id.size() <= 128
        && data.name is string && data.name.size() <= 200
        && data.category is string && data.category.size() <= 100
        && data.quantity is number
        && data.price is number
        && data.userId == request.auth.uid;
    }

    function isValidWorkHour(data) {
      return data.keys().hasAll(['id', 'date', 'hours', 'userId'])
        && data.id is string && data.id.size() <= 128
        && data.date is string && data.date.size() <= 50
        && data.hours is number && data.hours >= 0 && data.hours <= 24
        && data.userId == request.auth.uid;
    }

    // --- Rules ---

    match /transactions/{transactionId} {
      allow read: if isOwner(existing());
      allow create: if isSignedIn() && isValidId(transactionId) && isValidTransaction(incoming()) 
        && incoming().createdAt == request.time;
      allow update: if isOwner(existing()) && isValidTransaction(incoming())
        && incoming().diff(existing()).affectedKeys().hasOnly(['amount', 'subTotal', 'discount', 'tax', 'advance', 'due', 'items', 'type', 'category', 'paymentMethod', 'workStatus', 'paymentSplit', 'cashReceived', 'changeDue', 'customer', 'note', 'updatedAt'])
        && incoming().updatedAt == request.time
        && incoming().createdAt == existing().createdAt;
      allow delete: if isOwner(existing());
    }

    match /inventory/{itemId} {
      allow read: if isOwner(existing());
      allow create: if isSignedIn() && isValidId(itemId) && isValidInventory(incoming());
      allow update: if isOwner(existing()) && isValidInventory(incoming())
        && incoming().userId == existing().userId;
      allow delete: if isOwner(existing());
    }

    match /workHours/{hourId} {
      allow read: if isOwner(existing());
      allow create: if isSignedIn() && isValidId(hourId) && isValidWorkHour(incoming());
      allow update: if isOwner(existing()) && isValidWorkHour(incoming())
        && incoming().userId == existing().userId;
      allow delete: if isOwner(existing());
    }

    match /partUsage/{usageId} {
      allow read: if isOwner(existing());
      allow create: if isSignedIn() && isValidId(usageId) && incoming().userId == request.auth.uid;
      allow delete: if isOwner(existing());
    }

    match /categories/{categoryId} {
      allow read: if isOwner(existing());
      allow create: if isSignedIn() && isValidId(categoryId) && incoming().userId == request.auth.uid;
      allow delete: if isOwner(existing());
    }

    match /settings/{settingId} {
      allow read: if isSignedIn() && (resource == null || resource.data.userId == request.auth.uid);
      allow write: if isSignedIn() && isValidId(settingId) && incoming().userId == request.auth.uid;
    }
  }
}
